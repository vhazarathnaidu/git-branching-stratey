pipeline 
{
    agent any 
    triggers
    {
        pollSCM('H/5 * * * *')
    }
   
    stages
    {
        stage('git')
        {
            steps 
            {
                git branch: 'feature-ep-005-task-001', url:'https://github.com/vhazarathnaidu/git-branching-stratey.git'
            }
        }
        stage('build')
        {
            steps 
            {
                echo 'build started'
                 dir('java') {
                    bat 'javac Hello.java'
                    bat '''java Hello'''
                    bat 'javac Add.java'
                    bat '''Add Hello'''
               
                }
            }
        }
    }
}