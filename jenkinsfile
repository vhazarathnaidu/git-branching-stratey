pipeline 
{
    agent any 
    triggers
    {
        pollSCM('H/5 * * * *')
    }
    environment{
        set "JAVA_HOME=D:\sftp\jdk-21.0.9"
        set "PATH=%JAVA_HOME%\bin;%PATH%"
        set "MAVEN_HOME=D:\sftp\apache-maven-3.9.6"
        set "PATH=%MAVEN_HOME%\bin;%PATH%"
    }
    stages
    {
        stage('git')
        {
            steps 
            {
                git branch: 'feature-ep-005-task-001', url:'https://github.com/vhazarathnaidu/git-branching-stratey.git'
            }
        }
        stage('build')
        {
            steps 
            {
                echo 'build started'
                cd java
                javac Hello.java
                java Hello
            }
        }
    }
}