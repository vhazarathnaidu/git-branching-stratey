pipeline 
{
    agent any 
	environment {
        NODE_HOME = 'D:\\sftp\\node-v24.11.0-win-x64'
        PATH = "%NODE_HOME%"
    }
    triggers
    {
        pollSCM('H/2 * * * *')
    }
   
    stages
    {
        stage('git')
        {
            steps 
            {
                git branch: 'feature-ep-005-task-002', url:'https://github.com/vhazarathnaidu/git-branching-stratey.git'
            }
        }
        stage('build')
        {
            steps 
            {
                echo 'build started'
                 dir('node') {
                  bat 'node Hello.js'
                }
            }
        }
    }
}
